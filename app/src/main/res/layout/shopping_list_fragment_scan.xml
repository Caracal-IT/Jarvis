<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <androidx.camera.view.PreviewView
        android:id="@+id/cameraPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Scanning overlay frame -->
    <View
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_gravity="center"
        android:background="@drawable/shopping_list_bg_scan_frame" />

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#88000000"
        android:padding="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/shared_ic_arrow_back"
            android:contentDescription="@string/action_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/iron_man_gold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/title_scan_barcode"
            android:textColor="@color/iron_man_gold"
            android:textSize="@dimen/text_size_body"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

    </LinearLayout>

    <!-- Bottom hint -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:text="@string/hint_scan_barcode"
        android:textColor="@color/iron_man_cyan"
        android:textSize="@dimen/text_size_small"
        android:fontFamily="monospace"
        android:gravity="center"
        android:background="#88000000"
        android:padding="@dimen/spacing_medium" />

</FrameLayout>
