<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/replenish_item_height"
    android:layout_margin="@dimen/spacing_small"
    android:background="@drawable/shopping_list_bg_item_card"
    android:orientation="horizontal"
    android:padding="@dimen/spacing_medium"
    android:gravity="center_vertical">

    <FrameLayout
        android:layout_width="@dimen/replenish_item_image_size"
        android:layout_height="@dimen/replenish_item_image_size"
        android:background="@drawable/shopping_replenish_bg_icon_circle"
        android:padding="4dp">

        <ImageView
            android:id="@+id/ivReplenishItemImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/cd_item_image"
            android:scaleType="centerInside"
            android:padding="4dp" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="@dimen/spacing_medium">

        <TextView
            android:id="@+id/tvReplenishItemName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/iron_man_gold"
            android:textSize="@dimen/text_size_body"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tvBarcodeCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/iron_man_cyan"
            android:textSize="@dimen/text_size_small"
            android:fontFamily="monospace"
            android:visibility="gone" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnItemBarcode"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="@dimen/spacing_small"
        android:src="@drawable/shopping_list_ic_barcode_scan"
        android:contentDescription="@string/cd_scan_barcode"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:tint="@color/iron_man_cyan" />

    <Button
        android:id="@+id/btnAddToList"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/action_add"
        android:textColor="@color/iron_man_gold"
        android:backgroundTint="@color/iron_man_red"
        android:textSize="@dimen/text_size_small"
        android:fontFamily="monospace" />

</LinearLayout>
