<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/spacing_small"
    android:background="@drawable/bg_list_item_card"
    android:orientation="horizontal"
    android:padding="@dimen/spacing_medium"
    android:gravity="center_vertical"
    android:minHeight="48dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvItemName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/iron_man_gold"
            android:textSize="@dimen/text_size_body"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tvBarcodeCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/iron_man_cyan"
            android:textSize="@dimen/text_size_small"
            android:fontFamily="monospace"
            android:visibility="gone" />

    </LinearLayout>

    <ImageButton
        android:id="@+id/btnItemMenu"
        android:layout_width="@dimen/icon_size_menu"
        android:layout_height="@dimen/icon_size_menu"
        android:src="@android:drawable/ic_menu_more"
        android:contentDescription="@string/cd_item_menu"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:tint="@color/iron_man_gold" />

</LinearLayout>
