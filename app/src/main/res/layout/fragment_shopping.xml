<?xml version="1.0" encoding="utf-8"?>
<!--
    Placeholder layout for the Shopping feature fragment.
    Displays a centred "Coming Soon" message styled to the Jarvis / Iron Man theme.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_tech">

    <TextView
        android:id="@+id/tvShoppingTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_shopping"
        android:textColor="@color/iron_man_gold_dark"
        android:textSize="@dimen/text_size_title"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        app:layout_constraintBottom_toTopOf="@id/tvShoppingPlaceholder"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/tvShoppingPlaceholder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_medium"
        android:text="@string/placeholder_coming_soon"
        android:textColor="@color/iron_man_cyan"
        android:textSize="@dimen/text_size_body"
        android:fontFamily="monospace"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvShoppingTitle" />

</androidx.constraintlayout.widget.ConstraintLayout>

