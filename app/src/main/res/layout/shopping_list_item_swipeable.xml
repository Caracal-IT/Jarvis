<?xml version="1.0" encoding="utf-8"?>
<!-- Shopping list item with swipe-to-reveal action buttons -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/spacing_small"
    android:clipChildren="true"
    android:clipToPadding="true">

    <!-- Background actions revealed on swipe - changes color based on swipe direction -->
    <View
        android:id="@+id/actionsBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/swipe_action_green_transparent" />


    <!-- Left actions container (revealed when swiping right) - EDIT BUTTON -->
    <LinearLayout
        android:id="@+id/leftActions"
        android:layout_width="80dp"
        android:layout_height="match_parent"
        android:alpha="0"
        android:visibility="invisible">

        <ImageButton
            android:id="@+id/btnRename"
            android:layout_width="80dp"
            android:layout_height="match_parent"
            android:src="@drawable/shopping_list_ic_rename"
            android:contentDescription="@string/action_rename"
            android:background="?attr/selectableItemBackground"
            app:tint="@color/iron_man_gold" />

    </LinearLayout>

    <!-- Right action button (DELETE - revealed when swiping left) -->
    <ImageButton
        android:id="@+id/btnDelete"
        android:layout_width="80dp"
        android:layout_height="match_parent"
        android:src="@android:drawable/ic_menu_delete"
        android:contentDescription="@string/action_remove"
        android:background="?attr/selectableItemBackground"
        android:alpha="0"
        android:visibility="invisible"
        android:layout_gravity="end"
        app:tint="@color/iron_man_gold" />


    <!-- Foreground item (swipes over the background) -->
    <LinearLayout
        android:id="@+id/foreground"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/shopping_list_bg_item_card_opaque"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_medium"
        android:minHeight="48dp">

        <FrameLayout
            android:layout_width="@dimen/replenish_item_image_size"
            android:layout_height="@dimen/replenish_item_image_size"
            android:background="@drawable/shopping_list_bg_icon_circle"
            android:padding="4dp">

            <ImageView
                android:id="@+id/ivShoppingItemImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerInside"
                android:contentDescription="@string/cd_item_image" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/spacing_medium">

            <TextView
                android:id="@+id/tvItemName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/iron_man_gold"
                android:textSize="@dimen/text_size_body"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tvBarcodeCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/iron_man_cyan"
                android:textSize="@dimen/text_size_small"
                android:fontFamily="monospace"
                android:visibility="gone" />
        </LinearLayout>

        <!-- NEW: Inline barcode action icon (no visible text) -->
        <ImageButton
            android:id="@+id/btnItemBarcode"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="@dimen/spacing_small"
            android:src="@drawable/shopping_list_ic_barcode_scan"
            android:contentDescription="@string/cd_scan_barcode"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/iron_man_cyan" />

    </LinearLayout>

</FrameLayout>
